{
  "expo": {
    "name": "unbounded",
    "slug": "unbounded",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "unbounded",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.normod.unbounded"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3381FF"
      },
      "package": "com.normod.unbounded"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d38bfccf-2b75-467b-889e-11a9a966a5c0"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3381FF",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow unbounded to access your microphone for voice messages",
          "speechRecognitionPermission": "Allow unbounded to use speech recognition to transcribe your voice"
        }
      ]
    ]
  }
}