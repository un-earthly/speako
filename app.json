{
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-6826771706478909~1596967945",
    "ios_app_id": "ca-app-pub-6826771706478909~1596967945"
  },
  "expo": {
    "name": "Speako",
    "slug": "speako",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/appstore.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "speako",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.champaius.speako",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow Speako to use speech recognition to transcribe your voice",
        "NSMicrophoneUsageDescription": "Allow Speako to access your microphone for voice messages"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3381FF"
      },
      "package": "com.champaius.speako",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "462239e7-60bd-4c41-8ce6-8d4523bfdea1"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3381FF",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Speako to access your microphone for voice messages",
          "speechRecognitionPermission": "Allow Speako to use speech recognition to transcribe your voice"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6826771706478909~1596967945",
          "iosAppId": "ca-app-pub-6826771706478909~1596967945"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3381FF"
        }
      ]
    ],
    "owner": "champius"
  }
}
