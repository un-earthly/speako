{
  "react-native-google-mobile-ads": {
    "android_app_id": "ca-app-pub-6826771706478909~1596967945",
    "ios_app_id": "ca-app-pub-6826771706478909~1596967945"
  },
  "expo": {
    "name": "Speako",
    "slug": "speako",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/appstore.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "speako",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.champaius.speako"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3381FF"
      },
      "package": "com.champaius.speako"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d38bfccf-2b75-467b-889e-11a9a966a5c0"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#3381FF",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow Speako to access your microphone for voice messages",
          "speechRecognitionPermission": "Allow Speako to use speech recognition to transcribe your voice"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6826771706478909~1596967945",
          "iosAppId": "ca-app-pub-6826771706478909~1596967945"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.champaius.speako",
          "enableGooglePay": true
        }
      ]
    ]
  }
}